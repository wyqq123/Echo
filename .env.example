# Copy to `.env` and fill in values. `.env` is gitignored.

# PostgreSQL (e.g. docker compose: postgresql://echo:echo@localhost:5432/echo)
DATABASE_URL=

# Required for JWT access tokens (use a long random string in production)
JWT_SECRET=

DASHSCOPE_API_KEY=
# Optional overrides (defaults work for most setups):
# PORT=3001
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_CHAT_MODEL=qwen-plus
# QWEN_EMBED_MODEL=text-embedding-v2
